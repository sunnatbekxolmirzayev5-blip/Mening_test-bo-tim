import telebot
import random

API_TOKEN = '8041216411:AAGvwsCzDNlJNbKCXq8gpjWy8rkAZz5hqyg'  # Bu yerga bot tokeningizni yozing
bot = telebot.TeleBot(API_TOKEN)

user_games = {}  # foydalanuvchilar o'yin holati saqlanadi

@bot.message_handler(commands=['start'])
def start_game(message):
    bot.send_message(message.chat.id, "Salom! Men o'yin botman. 1-100 oralig'ida sonni topishga harakat qiling. /play bilan boshlang!")

@bot.message_handler(commands=['play'])
def play_game(message):
    number = random.randint(1, 100)
    user_games[message.chat.id] = number
    bot.send_message(message.chat.id, "Men 1 dan 100 gacha son o'yladim. Taxmin qilganingizni yozing:")

@bot.message_handler(func=lambda message: True)
def guess_number(message):
    chat_id = message.chat.id
    if chat_id not in user_games:
        bot.send_message(chat_id, "O'yinni boshlash uchun /play buyrug'ini yuboring!")
        return

    try:
        guess = int(message.text)
    except ValueError:
        bot.send_message(chat_id, "Iltimos, faqat son kiriting!")
        return

    target = user_games[chat_id]
    if guess < target:
        bot.send_message(chat_id, "Oliyroq sonni o'ylang ⬆️")
    elif guess > target:
        bot.send_message(chat_id, "Pastroq sonni o'ylang ⬇️")
    else:
        bot.send_message(chat_id, f"Tabriklaymiz! Siz {target} sonini topdingiz 🎉")
        del user_games[chat_id]  # o'yin tugadi

bot.polling()
